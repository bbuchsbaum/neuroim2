> coords <- matrix(c(1,1,1, 2,2,2), ncol=3, byrow=TRUE)
> roi_coords <- ROICoords(coords)
> 
> # Get coordinates in voxel space
> vox_coords <- coords(roi_coords)
> # First coordinate is (1,1,1)
