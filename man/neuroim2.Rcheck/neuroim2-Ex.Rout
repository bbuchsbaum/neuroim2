> 
> flush(stderr()); flush(stdout())
> 
> ### Name: NeuroVol
> ### Title: NeuroVol: 3D Neuroimaging Volume Class
> ### Aliases: NeuroVol
> 
> ### ** Examples
> 
> bspace <- NeuroSpace(c(64,64,64), spacing=c(1,1,1))
> dat <- array(rnorm(64*64*64), c(64,64,64))
> bvol <- NeuroVol(dat,bspace, label="test")
> 
