> indmask <- sort(sample(1:(24*24*24), 100))
> svol <- as.sparse(bvol, indmask)
> 
> 
> mask <- LogicalNeuroVol(runif(length(indmask)), space=space(bvol), indices=indmask)
> sum(mask) == 100
