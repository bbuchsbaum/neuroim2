> 
> # Create a sparse 3D brain image
> dim <- c(64L, 64L, 64L)
> space <- NeuroSpace(dim = dim, origin = c(0, 0, 0), spacing = c(1, 1, 1))
> sparse_data <- Matrix::sparseVector(x = c(1, 2, 3),
+                                     i = c(100, 1000, 10000),
+                                     length = prod(dim))
> sparse_vol <- new("SparseNeuroVol", space = space, data = sparse_data)
